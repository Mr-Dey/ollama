# ─── Ollama Chat — Environment overrides ─────────────────────────────────────
# Copy this file to .env and customize. Values here override config.json.
# Loaded by run.sh and exported to the backend systemd service / pods.

# ── Secrets ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# MongoDB
MONGO_USER=ollamaadmin
MONGO_PASS=change-me-mongo-password

# Cluster SSH (cluster mode only)
SSH_PASSWORD=

# ── SMTP — for forgot-password emails ────────────────────────────────────────
# Leave SMTP_HOST empty for dev mode (OTPs printed to console / returned in API)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=app-specific-password    # NOT your real password
#   SMTP_FROM=you@gmail.com

# ── Dev flags ────────────────────────────────────────────────────────────────
# Return OTP in API response when SMTP is not configured (default: true if no SMTP_HOST)
DEV_OTP_IN_RESPONSE=true
